{
  "name": "agents-hive",
  "version": "0.6.0",
  "description": "Multi-agent workspace manager for Claude Code, Gemini CLI, and Codex CLI",
  "type": "module",
  "bin": {
    "hive": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun run src/cli.ts",
    "start": "bun dist/cli.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "keywords": ["ai", "agents", "claude", "gemini", "codex", "cli", "workspace"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.13.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "8.57.1"
  }
}
